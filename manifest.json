{
    "manifest_version": 3,
    "name": "KingOfTime給与計算",
    "version": "1.7",
    "description": "Parses work time tables from KingOfTime admin pages",
    "permissions": [
      "activeTab",
      "storage"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_title": "KingOfTime給与計算",
      "default_popup": "popup.html"
    },
    "options_ui": {
      "page": "options.html",
      "open_in_tab": true
    },
    "content_scripts": [
      {
        "matches": ["https://s3.ta.kingoftime.jp/admin/*"],
        "js": ["content.js"]
      }
    ]
  }