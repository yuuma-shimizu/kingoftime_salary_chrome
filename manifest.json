{
    "manifest_version": 3,
    "name": "KingOfTime Table Parser",
    "version": "1.0",
    "description": "Parses work time tables from KingOfTime admin pages",
    "permissions": ["activeTab"],
    "content_scripts": [
      {
        "matches": ["https://s3.ta.kingoftime.jp/admin/*"],
        "js": ["content.js"]
      }
    ]
  }